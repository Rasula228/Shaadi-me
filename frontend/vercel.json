{
  "images": {
    "sizes": [256, 384, 640, 750, 828, 1080, 1200, 1920, 2048, 3840],
    "remotePatterns": [
      {
        "protocol": "https",
        "hostname": "images.pexels.com"
      },
      {
        "protocol": "https",
        "hostname": "commons.wikimedia.org"
      }
    ]
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

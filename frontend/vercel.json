{
  "images": {
    "remotePatterns": [
      {
        "protocol": "https",
        "hostname": "images.pexels.com"
      },
      {
        "protocol": "https",
        "hostname": "commons.wikimedia.org"
      }
    ]
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
